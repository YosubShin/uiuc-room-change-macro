{
  "manifest_version": 2,
  "name": "UIUC Room Change Macro",
  "description": "Enables one to search for new openings for the university housing",
  "version": "1.0",
  "permissions": [
    "https://starrez.housing.illinois.edu/"
  ],
  "content_scripts": [ {
    "all_frames": true,
    "js": ["jquery-1.11.0.min.js", "content.js"],
    "matches": ["https://starrez.housing.illinois.edu/*"],
    "run_at": "document_end"
  }],
  "web_accessible_resources": [
    "inject.js", "song.mp3"
  ]
}
